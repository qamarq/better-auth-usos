{
  "name": "better-auth-usos",
  "version": "1.0.0",
  "description": "USOS OAuth 1.0a authentication plugin for Better Auth",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "pnpm build",
    "lint": "pnpm lint:style && pnpm lint:typecheck",
    "lint:style": "eslint src --ext .ts",
    "lint:typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\""
  },
  "peerDependencies": {
    "better-auth": "^1.5.0",
    "crypto-js": "^4.2.0",
    "oauth-1.0a": "^2.2.6",
    "zod": "^3.0.0 || ^4.0.0"
  },
  "dependencies": {
    "better-auth": "^1.5.4",
    "crypto-js": "^4.2.0",
    "oauth-1.0a": "^2.2.6"
  },
  "keywords": [
    "better-auth",
    "better-auth-plugin",
    "usos",
    "oauth",
    "authentication",
    "pwr",
    "poland"
  ],
  "author": "Kamil Marczak",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/qamarq/better-auth-usos"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.1",
    "@semantic-release/npm": "^12.0.1",
    "@types/crypto-js": "^4.2.2",
    "@types/node": "^25.3.5",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.1",
    "semantic-release": "^24.2.0",
    "typescript": "^5.9.3",
    "zod": "^4.3.6"
  }
}
